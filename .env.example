# Explicit unprotected mode for local/preview diagnostics only
DEV_MODE=false

# OpenAI (server only)
OPENAI_API_KEY=
OPENAI_SPECIALIST_MODEL=
OPENAI_ADVISOR_MODEL=

# Cloudflare Turnstile (required unless NODE_ENV=development or DEV_MODE=true)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upstash Redis REST (required unless NODE_ENV=development or DEV_MODE=true)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
